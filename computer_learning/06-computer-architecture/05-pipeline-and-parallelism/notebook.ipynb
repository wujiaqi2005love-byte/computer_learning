    "# Q4: 用 NumPy 实现两个 1000 万维向量的点积，对比循环和向量化\n",
    "\n",
    "size = 10_000_000\n",
    "a = np.random.randn(size).astype(np.float32)\n",
    "b = np.random.randn(size).astype(np.float32)\n",
    "\n",
    "# 向量化版本\n",
    "start = time_module.perf_counter()\n",
    "dot_vec = np.dot(a, b)\n",
    "vec_time = time_module.perf_counter() - start\n",
    "\n",
    "# 循环版本（只跑前 50 万个，不然太慢）\n",
    "subset = 500_000\n",
    "start = time_module.perf_counter()\n",
    "dot_loop = sum(float(a[i]) * float(b[i]) for i in range(subset))\n",
    "loop_time = time_module.perf_counter() - start\n",
    "\n",
    "est_loop_full = loop_time * (size / subset)\n",
    "print(f\"Q4: 向量点积 {size:,} 维\")\n",
    "print(f\"  NumPy (SIMD):  {vec_time:.3f}s\")\n",
    "print(f\"  循环 (预估):   {est_loop_full:.1f}s\")\n",
    "print(f\"  加速比:        {est_loop_full / vec_time:.0f}x\")\n",
    "print(f\"  ✅ 结果一致:   {abs(dot_vec - dot_loop * (size/subset)) / abs(dot_vec) < 0.01}\")"
