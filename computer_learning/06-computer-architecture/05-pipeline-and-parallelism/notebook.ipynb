   "source": [
    "# ============================================\n",
    "# 编译器指令调度演示\n",
    "# ============================================\n",
    "\n",
    "def compiler_scheduling_demo():\n",
    "    print(\"📊 编译器调度消除数据冒险\\n\")\n",
    "    \n",
    "    print(\"原始代码:\")\n",
    "    print(\"  ADD  R1, R2, R3    ; R1 = a + b\")\n",
    "    print(\"  SUB  R4, R1, R5    ; R4 = R1 - c  ← 需要等 R1\")\n",
    "    print(\"  MUL  R6, R7, R8    ; R6 = d * e  ← 不依赖 R1!\")\n",
    "    print()\n",
    "    \n",
    "    print(\"调度后:\")\n",
    "    print(\"  ADD  R1, R2, R3    ; R1 = a + b\")\n",
    "    print(\"  MUL  R6, R7, R8    ; R6 = d * e  ← 移到这里，填充延迟槽\")\n",
    "    print(\"  SUB  R4, R1, R5    ; R4 = R1 - c  ← 这时 R1 已经好了\")\n",
    "    print()\n",
    "    print(\"💡 编译器把不依赖 R1 的 MUL 插入 ADD 和 SUB 之间，消除了停顿\")\n",
    "\n",
    "compiler_scheduling_demo()"
   ]
