    "---\n",
    "## 5.1 流水线模拟器\n",
    "\n",
    "先看对比：没有流水线 vs 有流水线。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-2",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================\n",
    "# 非流水线 vs 流水线 CPU 模拟\n",
    "# ============================================\n",
    "\n",
    "class NonPipelinedCPU:\n",
    "    \"\"\"没有流水线的 CPU：一条指令完全执行完才取下一条\"\"\"\n",
    "    def __init__(self):\n",
    "        self.cycles = 0\n",
    "        self.completed = 0\n",
    "    \n",
    "    def run(self, instructions):\n",
    "        \"\"\"每条指令 4 个周期（IF+ID+EX+WB），顺序执行\"\"\"\n",
    "        for i in range(len(instructions)):\n",
    "            self.cycles += 4\n",
    "            self.completed += 1\n",
    "        return self.cycles\n",
    "\n",
    "\n",
    "class PipelinedCPU:\n",
    "    \"\"\"五级流水线 CPU：IF | ID | EX | MEM | WB\"\"\"\n",
    "    def __init__(self):\n",
    "        self.cycles = 0\n",
    "        self.completed = 0\n",
    "        self.stalls = 0\n",
    "        # 流水线寄存器（每个阶段存一条指令）\n",
    "        self.pipeline = [None] * 5  # [IF, ID, EX, MEM, WB]\n",
    "    \n",
    "    def run(self, instructions, hazards=None):\n",
    "        \"\"\"\n",
    "        运行流水线。\n",
    "        hazards: list of (cycle, stage, stall_cycles) — 在哪个周期哪个阶段插入停顿\n",
    "        \"\"\"\n",
    "        if hazards is None:\n",
    "            hazards = []\n",
    "        \n",
    "        instr_queue = list(instructions)\n",
    "        hazard_map = {(h[0], h[1]): h[2] for h in hazards}\n",
    "        stalled_until = {}  # {stage: 停顿到哪个周期}\n",
    "        \n",
    "        while instr_queue or any(p is not None for p in self.pipeline):\n",
    "            self.cycles += 1\n",
    "            \n",
    "            # ── WB 阶段 ──\n",
    "            if self.pipeline[4] is not None:\n",
    "                self.completed += 1\n",
    "                self.pipeline[4] = None\n",
    "            \n",
    "            # ── MEM 阶段 → WB ──\n",
    "            if self.cycles >= stalled_until.get('MEM', 0):\n",
    "                self.pipeline[4] = self.pipeline[3]\n",
    "                self.pipeline[3] = None\n",
    "            \n",
    "            # ── EX 阶段 → MEM ──\n",
    "            if self.cycles >= stalled_until.get('EX', 0):\n",
    "                self.pipeline[3] = self.pipeline[2]\n",
    "                self.pipeline[2] = None\n",
    "            \n",
    "            # ── ID 阶段 → EX ──\n",
    "            if self.cycles >= stalled_until.get('ID', 0):\n",
    "                self.pipeline[2] = self.pipeline[1]\n",
    "                self.pipeline[1] = None\n",
    "            \n",
    "            # ── IF 阶段 → ID ──\n",
    "            if self.cycles >= stalled_until.get('IF', 0):\n",
    "                self.pipeline[1] = self.pipeline[0]\n",
    "                self.pipeline[0] = None\n",
    "            \n",
    "            # ── 取新指令 → IF ──\n",
    "            if self.pipeline[0] is None and instr_queue:\n",
    "                if self.cycles >= stalled_until.get('IF', 0):\n",
    "                    self.pipeline[0] = instr_queue.pop(0)\n",
    "            \n",
    "            # 检查是否有 Hazard\n",
    "            for stage_idx, stage_name in enumerate(['IF', 'ID', 'EX', 'MEM', 'WB']):\n",
    "                if (self.cycles, stage_name) in hazard_map:\n",
    "                    stall = hazard_map[(self.cycles, stage_name)]\n",
    "                    stalled_until[stage_name] = self.cycles + stall\n",
    "                    self.stalls += stall\n",
    "        \n",
    "        return self.cycles\n",
    "\n",
    "\n",
    "def compare_pipeline():\n",
    "    \"\"\"对比非流水线和流水线\"\"\"\n",
    "    instructions = list(range(10))  # 10 条指令\n",
    "    \n",
    "    # 非流水线\n",
    "    non_pipe = NonPipelinedCPU()\n",
    "    non_cycles = non_pipe.run(instructions)\n",
    "    \n",
    "    # 流水线（无冒险）\n",
    "    pipe = PipelinedCPU()\n",
    "    pipe_cycles = pipe.run(instructions)\n",
    "    \n",
    "    print(\"📊 10 条指令执行时间对比\\n\")\n",
    "    print(f\"  非流水线: {non_cycles} 周期\")\n",
    "    print(f\"  流水线:   {pipe_cycles} 周期\")\n",
    "    print(f\"  加速比:   {non_cycles / pipe_cycles:.2f}x\")\n",
    "    \n",
    "    print(f\"\\n💡 理论加速比 ≈ 流水线级数 = 5x\")\n",
    "    print(f\"   实际稍低 (因流水线\"填充\"和\"排空\"需要时间)\")\n",
    "    print(f\"   指令越多，越接近理论值\")\n",
    "\n",
    "compare_pipeline()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================\n",
    "# 流水线可视化\n",
    "# ============================================\n",
    "\n",
    "def visualize_pipeline(num_instructions=8):\n",
    "    \"\"\"可视化流水线的时空图\"\"\"\n",
    "    stages = ['IF', 'ID', 'EX', 'MEM', 'WB']\n",
    "    \n",
    "    # 模拟：每条指令在时钟周期 t 执行哪个阶段\n",
    "    print(\"📊 流水线时空图 (每条指令 5 个阶段)\\n\")\n",
    "    \n",
    "    # 打印表头\n",
    "    header = \"周期 \"\n",
    "    for i in range(1, num_instructions + 5):\n",
    "        header += f\"| C{i:2d} \"\n",
    "    print(header)\n",
    "    print(\"-\" * (7 + (num_instructions + 4) * 6))\n",
    "    \n",
    "    for instr_idx in range(num_instructions):\n",
    "        row = f\"  I{instr_idx:2d} \"\n",
    "        for cycle in range(1, num_instructions + 5):\n",
    "            stage_idx = cycle - 1 - instr_idx\n",
    "            if 0 <= stage_idx < 5:\n",
    "                row += f\"| {stages[stage_idx]:4s}\"\n",
    "            else:\n",
    "                row += f\"| {'':4s}\"\n",
    "        print(row)\n",
    "    \n",
    "    print(f\"\\n  总周期数: {num_instructions + 4}\")\n",
    "    print(f\"  理论加速比: {(num_instructions * 5) / (num_instructions + 4):.2f}x\")\n",
    "    print(f\"  (如果指令数→∞，加速比→5x)\")\n",
    "\n",
    "visualize_pipeline(8)"
   ]
  },
