    "---\n",
    "## 5.4 超标量（Superscalar）模拟\n",
    "\n",
    "超标量 CPU 每个周期可以发射多条独立指令。关键在于识别哪些指令可以同时执行。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-13",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================\n",
    "# 超标量发射模拟\n",
    "# ============================================\n",
    "\n",
    "def superscalar_demo():\n",
    "    \"\"\"模拟超标量：每周期发射 2 条不相关的指令\"\"\"\n",
    "    \n",
    "    # 指令序列：(name, reads_regs, writes_regs)\n",
    "    instructions = [\n",
    "        (\"ADD R1, R2, R3\",   ['R2','R3'], ['R1']),\n",
    "        (\"SUB R4, R5, R6\",   ['R5','R6'], ['R4']),  # 与 I0 无关 → 可并行\n",
    "        (\"MUL R7, R1, R4\",   ['R1','R4'], ['R7']),  # 需要 R1,R4 → 等 I0,I1\n",
    "        (\"LOAD R8, [R9]\",    ['R9'], ['R8']),        # 与上面无关 → 可并行\n",
    "        (\"ADD R2, R2, #1\",   ['R2'], ['R2']),        # 写 R2 → 与 I0 RAW\n",
    "        (\"STORE [R9], R7\",   ['R9','R7'], []),       # 需要 R7 → 等 I2\n",
    "        (\"XOR R3, R3, R3\",   ['R3'], ['R3']),        # 无关 → 可并行\n",
    "        (\"AND R5, R4, R7\",   ['R4','R7'], ['R5']),   # 需要 R4,R7 → 等 I1,I2\n",
    "    ]\n",
    "    \n",
    "    pending_writes = {}  # {reg: 完成周期}\n",
    "    cycle = 0\n",
    "    issued = []\n",
    "    \n",
    "    print(\"📊 超标量发射（2路，每周期最多 2 条）\\n\")\n",
    "    print(f\"{'周期':>4s} | {'发射指令':<50s} | {'等待的寄存器'}\")\n",
    "    print(\"-\" * 80)\n",
    "    \n",
    "    while instructions:\n",
    "        cycle += 1\n",
    "        issued_this_cycle = []\n",
    "        remaining = []\n",
    "        \n",
    "        for instr in instructions:\n",
    "            if len(issued_this_cycle) >= 2:\n",
    "                remaining.append(instr)\n",
    "                continue\n",
    "            \n",
    "            name, reads, writes = instr\n",
    "            \n",
    "            # 检查 RAW 依赖：要读的寄存器有没有正在被前面指令写\n",
    "            blocked = False\n",
    "            for r in reads:\n",
    "                if r in pending_writes and pending_writes[r] > cycle:\n",
    "                    blocked = True\n",
    "                    break\n",
    "            \n",
    "            # 检查 WAW 依赖：要写的寄存器有没有被同周期指令写\n",
    "            for issued_name, _, issued_writes in issued_this_cycle:\n",
    "                for w in writes:\n",
    "                    if w in issued_writes:\n",
    "                        blocked = True\n",
    "                        break\n",
    "            \n",
    "            if blocked:\n",
    "                remaining.append(instr)\n",
    "            else:\n",
    "                issued_this_cycle.append(instr)\n",
    "                # 写后 1 个周期可用（简化）\n",
    "                for w in writes:\n",
    "                    pending_writes[w] = cycle + 1\n",
    "        \n",
    "        instructions = remaining\n",
    "        \n",
    "        if issued_this_cycle:\n",
    "            for name, _, _ in issued_this_cycle:\n",
    "                print(f\"{cycle:4d} | {name:<50s} |\")\n",
    "            issued.extend(issued_this_cycle)\n",
    "        else:\n",
    "            print(f\"{cycle:4d} | {'(停顿)':<50s} | 等待依赖解决\")\n",
    "    \n",
    "    print(f\"\\n✅ {len(issued)} 条指令在 {cycle} 个周期内完成\")\n",
    "    print(f\"   IPC = {len(issued) / cycle:.2f}（理想标量 IPC=1, 超标量 IPC 可 >1）\")\n",
    "\n",
    "superscalar_demo()"
   ]
