    "\n",
    "def forwarding_paths_demo():\n",
    "    \"\"\"展示各种 Forwarding 路径\"\"\"\n",
    "    print(\"📊 Forwarding 路径（Bypassing）\\n\")\n",
    "    \n",
    "    print(\"\"\"\n",
    "  ┌──────┐   ┌──────┐   ┌──────┐   ┌──────┐   ┌──────┐\n",
    "  │  IF  │→  │  ID  │→  │  EX  │→  │ MEM  │→  │  WB  │\n",
    "  └──────┘   └──┬───┘   └──┬───┘   └──┬───┘   └──┬───┘\n",
    "                │           │           │           │\n",
    "                │    ① 从 EX/MEM 转发到 EX (最近)\n",
    "                │           │           │           │\n",
    "                │           │    ② 从 MEM/WB 转发到 EX\n",
