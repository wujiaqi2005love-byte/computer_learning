    "# ============================================\n",
    "# SIMD 对比：循环 vs 向量化\n",
    "# ============================================\n",
    "\n",
    "import numpy as np\n",
    "import time as time_module\n",
    "\n",
    "def simd_benchmark():\n",
    "    \"\"\"对比标量循环和 SIMD 向量化的性能\"\"\"\n",
    "    \n",
    "    size = 10_000_000\n",
    "    A = np.random.randn(size).astype(np.float32)\n",
    "    B = np.random.randn(size).astype(np.float32)\n",
    "    \n",
    "    print(f\"📊 SIMD 向量化对比: {size:,} 个 float32 元素\\n\")\n",
    "    print(f\"  理论: AVX-256 一次处理 8 个 float32\")\n",
    "    print(f\"  理论加速比: ≈ 8x\\n\")\n",
    "    \n",
    "    # 1. 纯 Python 循环（标量）\n",
    "    start = time_module.perf_counter()\n",
    "    C_python = [A[i] + B[i] for i in range(min(size, 100000))]\n",
    "    py_time = time_module.perf_counter() - start\n",
    "    print(f\"  Python 循环 (10万次): {py_time:.3f}s  (太慢，只跑10万次)\")\n",
    "    \n",
    "    # 2. NumPy 向量化（利用 SIMD）\n",
    "    start = time_module.perf_counter()\n",
    "    C_numpy = A + B\n",
    "    np_time = time_module.perf_counter() - start\n",
    "    print(f\"  NumPy 向量化 (1000万次): {np_time:.3f}s\")\n",
    "    \n",
    "    # 估算全量 Python 循环的时间\n",
    "    est_py_full = py_time * (size / 100000)\n",
    "    print(f\"  Python 循环 (预估全量): {est_py_full:.1f}s\")\n",
    "    print(f\"\\n⚡ NumPy 向量化快约 {est_py_full / np_time:.0f}x\")\n",
    "    print(f\"💡 加速来源:\")\n",
    "    print(f\"   ① SIMD: 1条指令处理8个元素 (8x)\")\n",
    "    print(f\"   ② 编译优化: C vs Python 循环开销 (>10x)\")\n",
    "    print(f\"   ③ Cache友好: 连续内存访问\")\n",
    "\n",
    "simd_benchmark()"
   ]
