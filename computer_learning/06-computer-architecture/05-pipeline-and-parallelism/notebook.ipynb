    "---\n",
    "## 5.3 控制冒险与分支预测\n",
    "\n",
    "实现一个分支预测器，看不同策略的准确率。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-10",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================\n",
    "# 分支预测器实现\n",
    "# ============================================\n",
    "\n",
    "class BranchPredictor:\n",
    "    \"\"\"分支预测器\"\"\"\n",
    "    \n",
    "    def __init__(self, strategy='always_not_taken'):\n",
    "        \"\"\"\n",
    "        strategy: 'always_not_taken' | 'always_taken' | '1bit' | '2bit'\n",
    "        \"\"\"\n",
    "        self.strategy = strategy\n",
    "        self.history = {}     # {branch_addr: prediction}\n",
    "        self.two_bit = {}     # {branch_addr: counter (0-3)}\n",
    "        self.correct = 0\n",
    "        self.total = 0\n",
    "    \n",
    "    def predict(self, branch_addr):\n",
    "        \"\"\"预测是否跳转\"\"\"\n",
    "        if self.strategy == 'always_not_taken':\n",
    "            return False\n",
    "        elif self.strategy == 'always_taken':\n",
    "            return True\n",
    "        elif self.strategy == '1bit':\n",
    "            return self.history.get(branch_addr, False)\n",
    "        elif self.strategy == '2bit':\n",
    "            # 2-bit: counter >= 2 → predict taken\n",
    "            return self.two_bit.get(branch_addr, 1) >= 2\n",
    "        return False\n",
    "    \n",
    "    def update(self, branch_addr, actual_taken):\n",
    "        \"\"\"用实际结果更新预测器\"\"\"\n",
    "        predicted = self.predict(branch_addr)\n",
    "        self.total += 1\n",
    "        if predicted == actual_taken:\n",
    "            self.correct += 1\n",
    "        \n",
    "        if self.strategy == '1bit':\n",
    "            self.history[branch_addr] = actual_taken\n",
    "        elif self.strategy == '2bit':\n",
    "            old = self.two_bit.get(branch_addr, 1)  # 默认 weakly not taken\n",
    "            if actual_taken:\n",
    "                self.two_bit[branch_addr] = min(old + 1, 3)\n",
    "            else:\n",
    "                self.two_bit[branch_addr] = max(old - 1, 0)\n",
    "    \n",
    "    def accuracy(self):\n",
    "        \"\"\"返回准确率\"\"\"\n",
    "        return self.correct / self.total * 100 if self.total > 0 else 0\n",
    "\n",
    "\n",
    "# 生成测试数据：模拟一个典型的 loop 分支模式\n",
    "def generate_branch_pattern(pattern_type, length=100):\n",
    "    \"\"\"\n",
    "    生成分支序列 (branch_addr, taken)\n",
    "    \"\"\"\n",
    "    import random\n",
    "    random.seed(42)\n",
    "    \n",
    "    if pattern_type == 'loop':\n",
    "        # 循环：前 N-1 次跳转(回到循环头)，最后一次不跳(退出循环)\n",
    "        patterns = []\n",
    "        iteration = 10\n",
    "        for _ in range(length // iteration):\n",
    "            for j in range(iteration):\n",
    "                patterns.append((0x100, j < iteration - 1))\n",
    "        return patterns[:length]\n",
    "    \n",
    "    elif pattern_type == 'alternating':\n",
    "        # 交替 T/NT/NT/T/T/NT...\n",
    "        seq = [True, False, False, True, True, False]\n",
    "        return [(0x100, seq[i % len(seq)]) for i in range(length)]\n",
    "    \n",
    "    elif pattern_type == 'random':\n",
    "        return [(0x100, random.choice([True, False])) for _ in range(length)]\n",
    "    \n",
    "    elif pattern_type == 'mostly_taken':\n",
    "        return [(0x100, random.random() < 0.8) for _ in range(length)]\n",
    "    \n",
    "    return []\n",
    "\n",
    "# 测试各种策略\n",
    "print(\"📊 分支预测器准确率对比\\n\")\n",
    "\n",
    "strategies = ['always_not_taken', 'always_taken', '1bit', '2bit']\n",
    "patterns = ['loop', 'alternating', 'random', 'mostly_taken']\n",
    "\n",
    "for pattern_name in patterns:\n",
    "    print(f\"{'─' * 60}\")\n",
    "    print(f\"📋 模式: {pattern_name}\")\n",
    "    print(f\"{'─' * 60}\")\n",
    "    print(f\"{'策略':<20s} | {'准确率':>8s}\")\n",
    "    print(\"-\" * 32)\n",
    "    \n",
    "    branch_seq = generate_branch_pattern(pattern_name, 200)\n",
    "    \n",
    "    for strategy in strategies:\n",
    "        pred = BranchPredictor(strategy)\n",
    "        for addr, taken in branch_seq:\n",
    "            pred.update(addr, taken)\n",
    "        print(f\"{strategy:<20s} | {pred.accuracy():7.1f}%\")\n",
    "    print()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cell-11",
   "metadata": {},
   "source": [
    "### 🔍 观察\n",
    "\n",
    "- **Loop 模式**：2-bit 预测器优势显著——循环结束时只有一次误预测\n",
    "- **交替模式**：1-bit 每次都在追，2-bit 稍好但不完美\n",
    "- **随机模式**：所有策略都接近 50%——没法预测随机\n",
    "- **偏斜模式**（80% 跳转）：always_taken 反而最好\n",
    "\n",
    "> 现代 CPU 的分支预测器比这个复杂得多，使用全局历史 + 局部历史 + 神经网络，准确率 > 95%。"
   ]
  },
